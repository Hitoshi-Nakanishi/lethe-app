LOCAL_UID=1000
LOCAL_GID=1000
TASK_VERSION=3.51.1

# Container-local paths used by compose.yaml.
LETHE_DOCKER_DATA_PATH=/workspace/lethe-app/.docker-data
LETHE_DOCKER_CONFIG=/workspace/lethe-app/docker/default.toml

# Change this if host port 11434 is already in use.
OLLAMA_PORT=11434

# Linux GUI/audio users can pass host display settings through these variables.
# DISPLAY=:0
# WAYLAND_DISPLAY=wayland-0
# PULSE_SERVER=unix:/run/user/1000/pulse/native
